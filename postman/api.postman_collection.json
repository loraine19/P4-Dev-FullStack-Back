    {
      "name": "Download",
      "item": [
        {
          "name": "Get metadata - token valide (fichier auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('meta complète', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.status).to.eql('success');",
                  "  pm.expect(j.data.filename).to.be.a('string');",
                  "  pm.expect(j.data).to.have.property('mimeType');",
                  "  pm.expect(j.data).to.have.property('requiresPassword');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/download/{{shareToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["download", "{{shareToken}}"]
            }
          }
        },
        {
          "name": "Get metadata - token invalide → 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/download/token-qui-nexiste-pas",
              "host": ["{{baseUrl}}"],
              "path": ["download", "token-qui-nexiste-pas"]
            }
          }
        },
        {
          "name": "Download file - token valide → 200 stream",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('content-disposition header', () => {",
                  "  pm.expect(pm.response.headers.get('content-disposition')).to.include('attachment');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/download/{{anonToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["download", "{{anonToken}}"]
            },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
