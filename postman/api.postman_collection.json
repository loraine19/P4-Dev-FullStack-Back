{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "P4 Backend - Full API",
    "description": "Collection complète — auth, files, download, tags. Exécuter avec le backend démarré (npm run start:dev) et la BDD active (docker compose up -d).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - success",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('authEmail', 'loraine.test+' + ts + '@mail.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('status success', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.status).to.eql('success');",
                  "  pm.expect(j.data).to.eql(null);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"name\": \"{{authName}}\"\n}"
            }
          }
        },
        {
          "name": "Login - mobile (saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('token in body', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.status).to.eql('success');",
                  "  pm.expect(j.data.access_token).to.be.a('string');",
                  "  pm.environment.set('accessToken', j.data.access_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"isMobile\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Upload - authenticated",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('shareToken present', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.status).to.eql('success');",
                  "  pm.expect(j.data.shareToken).to.be.a('string');",
                  "  pm.expect(j.data.id).to.be.a('number');",
                  "  pm.environment.set('fileId', j.data.id);",
                  "  pm.environment.set('shareToken', j.data.shareToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/files", "host": ["{{baseUrl}}"], "path": ["files"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "postman/fixtures/test-upload.txt" },
                { "key": "expirationDays", "value": "7", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Upload - anonymous",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
