{
  "info": {
    "_postman_id": "f2f0d8c4-6f7d-4b0c-a7dd-b3df5f8b3d1a",
    "name": "P4 Backend - Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection Newman/Postman pour valider le bloc auth du backend."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"name\": \"{{authName}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.environment.set('authEmail', 'loraine.test+' + timestamp + '@mail.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('response is success', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "  pm.expect(json.message).to.be.a('string');",
                  "  pm.expect(json.data).to.eql(null);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - duplicate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"name\": \"{{authName}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "pm.test('response is error', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('error');",
                  "  pm.expect(json.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - web",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"isMobile\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response contains user and no access token', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "  pm.expect(json.data).to.have.property('user');",
                  "  pm.expect(json.data).to.not.have.property('access_token');",
                  "});",
                  "pm.test('cookie is returned', function () {",
                  "  pm.expect(pm.response.headers.get('Set-Cookie')).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - mobile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\",\n  \"isMobile\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response contains access token', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "  pm.expect(json.data).to.have.property('user');",
                  "  pm.expect(json.data).to.have.property('access_token');",
                  "  pm.environment.set('accessToken', json.data.access_token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout - bearer token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('response is success', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('success');",
                  "  pm.expect(json.data).to.eql(null);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "authEmail",
      "value": "loraine.test+auth@mail.com"
    },
    {
      "key": "authPassword",
      "value": "Password123!"
    },
    {
      "key": "authName",
      "value": "Loraine"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ]
}